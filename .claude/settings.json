{
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(uv:*)",
      "Bash(git:status:*)",
      "Bash(git:diff:*)",
      "Bash(git:log:*)",
      "Bash(git:add:*)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(docs/)",
      "Edit(configs/)",
      "Edit(scripts/)"
    ],
    "deny": [
      "Edit(.env)",
      "Read(.env)"
    ],
    "ask": [
      "Bash(git:commit:*)",
      "Bash(git:push:*)",
      "Edit(AGENTS.md)",
      "Edit(CLAUDE.md)",
      "Edit(pyproject.toml)"
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "cc-meta@qte77-claude-code-utils": true
  },
  "extraKnownMarketplaces": {
    "qte77-claude-code-utils": {
      "source": {
        "source": "github",
        "repo": "qte77/claude-code-utils-plugin"
      }
    }
  }
}
